      "x-ron-tuple-arity": 2
    },
    "Kind": {
      "oneOf": [
        {
          "x-ron-variant": "None",
          "x-ron-variant-shape": "unit"
        },
        {
          "x-ron-variant": "Id",
          "x-ron-variant-shape": "newtype",
          "x-ron-payload": {
            "type": "integer"
          }
        },
        {
          "x-ron-variant": "Pair",
          "x-ron-variant-shape": "tuple",
          "prefixItems": [
            {
              "type": "integer"
            },
            {
              "type": "string",
              "x-ron-kind": "char"
            }
          ]
        },
        {
          "x-ron-variant": "Named",
