// A scene with `resources` entirely OMITTED (only `entities` present). An
// omitted/empty `resources` is valid (FR-004 Edge Cases): the model must
// project zero resources and still read every entity's components.
(
    entities: {
        7: (
            components: {
                "bevy_transform::components::transform::Transform": (
                    translation: (x: 0.0, y: 0.0, z: 0.0),
                    rotation: (0.0, 0.0, 0.0, 1.0),
                    scale: (x: 1.0, y: 1.0, z: 1.0),
                ),
            },
        ),
    },
)
